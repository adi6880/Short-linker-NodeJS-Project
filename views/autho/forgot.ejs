<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forgot Password</title>
</head>
<body style="margin: 0; padding: 0; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f4f7f6; display: flex; justify-content: center; align-items: center; height: 100vh;">

    <div style="background-color: #ffffff; padding: 40px; border-radius: 10px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); width: 100%; max-width: 400px; text-align: center;">
        
        <div style="margin-bottom: 20px;">
            <div style="background-color: #e8f0fe; width: 60px; height: 60px; border-radius: 50%; display: flex; justify-content: center; align-items: center; margin: 0 auto 15px;">
                <span style="font-size: 30px; color: #1a73e8;">?</span>
            </div>
            <h2 style="margin: 0; color: #333; font-size: 24px;">Forgot Password?</h2>
            <p style="color: #666; font-size: 14px; margin-top: 10px;">Enter your email address and we'll send you a link to reset your password.</p>
        </div>

        <form action="#" method="POST">
            <div style="text-align: left; margin-bottom: 20px;">
                <label for="email" style="display: block; font-size: 14px; color: #555; margin-bottom: 8px; font-weight: 600;">Email Address</label>
                <input type="email" id="email" name="email" placeholder="hello@example.com" required 
                    style="width: 100%; padding: 12px 15px; border: 1px solid #ddd; border-radius: 6px; box-sizing: border-box; font-size: 16px; outline: none; transition: border-color 0.3s;">
            </div>

            <button type="submit" 
                style="width: 100%; background-color: #1a73e8; color: white; padding: 12px; border: none; border-radius: 6px; font-size: 16px; font-weight: 600; cursor: pointer; transition: background-color 0.3s;">
                Reset Password
            </button>
        </form>

        <div style="margin-top: 25px;">
            <a href="/login" style="color: #1a73e8; text-decoration: none; font-size: 14px; font-weight: 500;">&larr; Back to Login</a>
        </div>
    </div>

</body>
</html>