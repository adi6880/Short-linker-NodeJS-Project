<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Account</title>
</head>
<body style="margin: 0; padding: 0; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f4f7f6; display: flex; justify-content: center; align-items: center; min-height: 100vh;">

    <div style="background-color: #ffffff; padding: 40px; border-radius: 10px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); width: 100%; max-width: 400px; text-align: center; margin: 20px;">
        
        <h2 style="margin: 0 0 10px 0; color: #333; font-size: 28px;">Create Account</h2>
        <p style="color: #666; font-size: 14px; margin-bottom: 30px;">Join us today! It only takes a minute.</p>

        <form action="#" method="POST">
            
            <div style="text-align: left; margin-bottom: 20px;">
                <label for="name" style="display: block; font-size: 14px; color: #555; margin-bottom: 8px; font-weight: 600;">Full Name</label>
                <input type="text" id="name" name="name" placeholder="xyz" required 
                    style="width: 100%; padding: 12px 15px; border: 1px solid #ddd; border-radius: 6px; box-sizing: border-box; font-size: 16px; outline: none;">
            </div>

            <div style="text-align: left; margin-bottom: 20px;">
                <label for="email" style="display: block; font-size: 14px; color: #555; margin-bottom: 8px; font-weight: 600;">Email Address</label>
                <input type="email" id="email" name="email" placeholder="name@company.com" required 
                    style="width: 100%; padding: 12px 15px; border: 1px solid #ddd; border-radius: 6px; box-sizing: border-box; font-size: 16px; outline: none;">
            </div>

            <div style="text-align: left; margin-bottom: 25px;">
                <label for="password" style="display: block; font-size: 14px; color: #555; margin-bottom: 8px; font-weight: 600;">Password</label>
                <input type="password" id="password" name="password" placeholder="At least 8 characters" required 
                    style="width: 100%; padding: 12px 15px; border: 1px solid #ddd; border-radius: 6px; box-sizing: border-box; font-size: 16px; outline: none;">
            </div>

            <button type="submit" 
                style="width: 100%; background-color: #1a73e8; color: white; padding: 12px; border: none; border-radius: 6px; font-size: 16px; font-weight: 600; cursor: pointer;">
                Get Started
            </button>
        </form>

        <div style="margin-top: 25px; border-top: 1px solid #eee; padding-top: 20px;">
            <p style="color: #666; font-size: 14px;">Already have an account? <a href="/login" style="color: #1a73e8; text-decoration: none; font-weight: 600;">Log in</a></p>
        </div>
    </div>

</body>
</html>