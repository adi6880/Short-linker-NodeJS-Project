<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Email verification Page</title>
</head>

<body>
    <H1>Verify Your Email</H1>
    <div class="container">
        <span>Email:</span>

        <div class="content">
            <p>
                Your email has not been verify the email yet. Please verify your email by
                entering the 8-digit code or request a new verification link
            </p>
        </div>
        <form action="/resend-verification" method="POST" class="form-inline">
            <button type="submit" class="form-button">resend verification</button>
        </form>
    </div>
    <div class="card mt2">
        <div class="card-body">
            <form action="/verify-email-token" method="get">
                <div class="form-group">
                    <label for="token" class="control-label">
                        Enter 8-Digit Verification Code:
                    </label>
                    <input type="text"
                    name="token"
                    id="token"
                    maxlength="8"
                    pattern="\d{8}"
                    title="Please enter 8-digit number"
                    required
                    >
                </div>
                <input type="hidden" name="email" id="email" value=<%=email%>>

                <button type="submit" class="btn btn-primary">Verify Code</button>
            </form>
        </div>
    </div>
</body>

</html>